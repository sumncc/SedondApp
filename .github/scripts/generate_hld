#!/usr/bin/env bash
set -euo pipefail
source .github/scripts/common.sh

INPUT_PATHS="${1:-docs/generated/requirements}"
SLUG="${2:-sample-service}"
SOURCE_PR="${3:-0}"
SOURCE_BRANCH="${4:-unknown}"
OUT_DIR="${5:-docs/generated/hld}"
CONFIG_PATH="${6:-.github/agent-prompts/config.yml}"
PROMPT_PATH="${7:-.github/agent-prompts/generate_hld.md}"

require_file "$CONFIG_PATH"; require_file "$PROMPT_PATH"
ensure_dir "$OUT_DIR"

DIAGRAM_FMT="$(yaml_get documentation.diagramFormat)"
REQ_ID="REQ-${SLUG^^}-001"
HLD_ID="HLD-${SLUG^^}-001"

cat > "${OUT_DIR}/${SLUG}-hld.md" <<EOF
# High Level Design: ${SLUG}

- Traceability: ${REQ_ID} -> ${HLD_ID}
- Source PR: #${SOURCE_PR}
- Source Branch: ${SOURCE_BRANCH}
- Input Paths: ${INPUT_PATHS}
- Diagram Format: ${DIAGRAM_FMT}

## System Context
\`\`\`${DIAGRAM_FMT}
flowchart LR
  U[User] --> S[SampleService]
  S --> DB[(Database)]
\`\`\`

## Container Diagram
\`\`\`${DIAGRAM_FMT}
flowchart TB
  GW[API Gateway] --> APP[SampleService App]
  APP --> R[(Reactive Repo)]
\`\`\`

## Component Diagram
\`\`\`${DIAGRAM_FMT}
flowchart LR
  C[Controller] --> SV[Service]
  SV --> RP[Repository]
\`\`\`

## Key Sequence
\`\`\`${DIAGRAM_FMT}
sequenceDiagram
  actor User
  User->>Controller: HTTP request
  Controller->>Service: process()
  Service->>Repository: query()
  Repository-->>Service: data
  Service-->>Controller: response
  Controller-->>User: 200 OK
\`\`\`
EOF

echo "${OUT_DIR}/${SLUG}-hld.md"